<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.local.podblock</string>
    <key>ProgramArguments</key>
    <array>
        <string>__INSTALL_DIR__/podblock</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PODBLOCK_PREFERRED_INPUT</key>
        <string>DJI</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/podblock.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/podblock.err</string>
</dict>
</plist>
